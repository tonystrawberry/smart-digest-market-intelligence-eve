# Google Gemini (required)
GOOGLE_GENERATIVE_AI_API_KEY=

# Vercel AI Gateway alternative (e.g. google/gemini-2.5-flash) — not used when agent.ts calls @ai-sdk/google directly
# AI_GATEWAY_API_KEY=

# Legacy OpenAI — not used by default
# OPENAI_API_KEY=

# Discord (required for digest delivery)
DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=
DISCORD_BOT_TOKEN=

# YouTube watchlist override (optional — comma-separated channel IDs)
# Default list is in agent/lib/youtube-config.ts
# YOUTUBE_CHANNEL_IDS=UCxxxxxxxxxxxxxxxxxxxxxxxxxx,UCyyyyyyyyyyyyyyyyyyyyyyyyyy
